NODE_ENV=production
PORT=3100

# URLs
CLIENT_URL=https://app.robokids.vn

# Supabase Real Database (Production)
SUPABASE_URL=https://[YOUR_PRODUCTION_PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
JWT_SECRET=super-secret-production-jwt-key

# MQTT Broker Configure
MQTT_PORT=1883
MQTT_HOST=0.0.0.0

# Email configurations (Example: SendGrid, Resend)
EMAIL_SERVICE_API_KEY=your_email_api_key_here

# Payment (VNPay Sandbox/Live configurations)
VNPAY_TMN_CODE=your_tmn_code_here
VNPAY_HASH_SECRET=your_hash_secret_here
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://api.robokids.vn/api/payments/callback
