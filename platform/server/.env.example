# Supabase Configuration
SUPABASE_URL=https://nmjgwvgzekkiyymufpag.supabase.co
SUPABASE_ANON_KEY=sb_publishable_H_gUEImUGtd3T9DREevqKw_HPTi-jPC
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXX  # CẦN REVEAL từ Supabase dashboard > Settings > API

# Supabase Auth Configuration
# Get these from your Supabase project settings -> API
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret (optional - Supabase handles this by default)
# JWT_SECRET=your-jwt-secret-here

# Email Configuration (for welcome emails and password reset)
EMAIL_ENABLED=true
EMAIL_FROM=noreply@robokids.vn
EMAIL_SMTP_HOST=smtp.supabase.co
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASS=your-smtp-password

# Server Configuration
PORT=3100
NODE_ENV=development

# MQTT Broker (embedded Aedes)
MQTT_PORT=1883

# MiniMax AI Configuration
# Sign up at https://platform.minimax.chat to get API credentials
# NOTE: MiniMax is now fallback - GPT-4o is primary
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_ORGANIZATION_ID=your-organization-id
MINIMAX_ENDPOINT=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_MODEL=abab5.5-chat
MINIMAX_RATE_LIMIT_REQUESTS=30
MINIMAX_RATE_LIMIT_WINDOW_MS=60000

# OpenAI GPT-4o Configuration (PRIMARY AI)
# Sign up at https://platform.openai.com to get API credentials
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION_ID=your-organization-id  # Optional - for org-level API access
OPENAI_RATE_LIMIT_REQUESTS=20  # Lower limit due to GPT-4o cost
OPENAI_RATE_LIMIT_WINDOW_MS=60000

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# MoMo Payment Configuration (Vietnam mobile payment)
# Get credentials from MoMo merchant portal: https://business.momo.vn/
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_CALLBACK_URL=https://your-domain.com/api/payments/momo-callback

# Stripe Payment Configuration (International payments)
# Get keys from Stripe dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_ENDPOINT=https://api.stripe.com/v1/checkout/sessions